# Coinbase Developer Platform – required for OnchainKit wallet (connect, identity, etc.)
# Get yours: https://portal.cdp.coinbase.com/projects/api-keys/client-key
VITE_PUBLIC_ONCHAINKIT_API_KEY=

# WalletConnect (optional; for WalletConnect-compatible wallets in addition to Coinbase Wallet)
# VITE_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Backend (NestJS)
VITE_API_URL=http://localhost:3001
