# Privy – custodial/embedded wallet & auth (email, social, wallet)
# Create an app at https://dashboard.privy.io
VITE_PRIVY_APP_ID=cmmf9oguo01650cl1njvumkkr

# WalletConnect – for “Connect wallet” popup on mobile (MetaMask app opens to connect/sign). Get project ID at https://cloud.reown.com
# If unset, WalletConnect option is hidden; set it for mobile scan-and-pay.
# VITE_WALLETCONNECT_PROJECT_ID=

# Backend (NestJS) — for local dev use http://localhost:3001 (match payechoBackend PORT). For production set to your backend URL.
VITE_API_URL=http://localhost:3001

# Scan-to-pay: base URL used inside the QR code. Set in production so scanning opens your deployed app (e.g. https://app.payecho.xyz). If unset, QR uses current page origin.
# VITE_PUBLIC_APP_URL=https://app.payecho.xyz

# BankVault (payment pool) — must match backend BANK_VAULT_ADDRESS. QR encodes this as vault; customer pays to this contract (acceptPayment(merchant, amount, ref)).
VITE_BANK_VAULT_ADDRESS=
